    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "train_df, test_df = train_test_split(\n",
    "    df,\n",
    "    test_size=0.2,\n",
    "    random_state=42,\n",
    "    stratify=df['userId'] # the distribution of users in train & test is preserved\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 41,
   "id": "fe601c26",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.feature_extraction.text import TfidfVectorizer\n",
    "from sklearn.metrics.pairwise import cosine_similarity\n",
    "\n",
    "train_movie_ids = train_df['movieId'].unique()\n",
    "\n",
    "train_movie_text = (\n",
    "    movie_text[movie_text['movieId'].isin(train_movie_ids)]\n",
    "    .reset_index(drop=True)\n",
    ")\n",
    "\n",
    "# vectorization\n",
    "tfidf = TfidfVectorizer(stop_words='english')\n",
    "tfidf_matrix = tfidf.fit_transform(train_movie_text['content'])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 42,
   "id": "24666cce",
   "metadata": {},
   "outputs": [],
   "source": [
    "movie_id_to_index = dict(zip(train_movie_text['movieId'], train_movie_text.index))\n",
    "title_to_index    = dict(zip(train_movie_text['title'], train_movie_text.index))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 43,
   "id": "bc7f9053",
   "metadata": {},
   "outputs": [],
   "source": [
    "def recommend_similar_movies(title, n=5):\n",
    "    \n",
    "    if title not in title_to_index:\n",
    "        return \"Movie not found\"\n",
    "    \n",
    "    idx = title_to_index[title]\n",
    "    \n",
    "    sim_scores = cosine_similarity(tfidf_matrix[idx], tfidf_matrix).flatten()\n",
    "    \n",
    "    # Exclude itself and get top-N\n",
    "    top_idx = sim_scores.argsort()[-(n+1):-1][::-1]\n",
    "    \n",
    "    return train_movie_text['title'].iloc[top_idx].tolist()\n",
    "\n",
    "# outputs movie titles"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 44,
   "id": "111ebe7b",
   "metadata": {},
