   "outputs": [],
   "source": [
    "def hybrid_recommendations(user_id, df, n=5, cold_start_threshold=5):\n",
    " \n",
    "    user_ratings = df[df['userId'] == user_id]\n",
    "    \n",
    "    # 1. Content-based/Popularity fallback path\n",
    "    if len(user_ratings) < cold_start_threshold:\n",
    "        print(f\"User {user_id} has only {len(user_ratings)} ratings -> using content-based fallback\")\n",
    "        \n",
    "        if len(user_ratings) == 0:\n",
    "            # Truly new user: return globally most popular movies\n",
    "            popular = (df.groupby('movieId')['rating']\n",
    "                       .agg(['mean', 'count'])\n",
    "                       .query('count >= 50')\n",
    "                       .sort_values('mean', ascending=False)\n",
    "                       .head(n)\n",
    "                       .reset_index())\n",
    "            return popular[['movieId', 'mean']]\n",
    "        \n",
    "        # Fallback to content-based using the user's highest-rated movie\n",
    "        seed_movie_title = user_ratings.sort_values('rating', ascending=False).iloc[0]['title']\n",
    "        return recommend_similar_movies(seed_movie_title, n=n)\n",
    "\n",
    "    # 2. Collaborative path (Existing user)\n",
    "    return get_top_n(best_model, trainset,data,user_id, n=n)\n",
    "\n"
   ]
  },
